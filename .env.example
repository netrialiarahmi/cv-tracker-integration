# Microsoft Planner Sync Configuration
# Copy this to .env and fill in your actual values

# Microsoft Account Credentials
MICROSOFT_EMAIL=your-email@example.com
MICROSOFT_PASSWORD=your-password

# Planner URL
PLANNER_URL=https://tasks.office.com/your-organization/Home/Planner/#/plantaskboard?groupId=xxx&planId=xxx

# Data file path (relative to project root)
DATA_FILE=data/hiring-data.json

# Timezone (default: Asia/Jakarta)
TIMEZONE=Asia/Jakarta
